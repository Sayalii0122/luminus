	measure 'Occupied Rate Prior Year' = ```
			
			VAR SelectedStartDate = MIN(PeriodDates[Date]) 
			VAR SelectedEndDate = MAX(PeriodDates[Date]) 
			VAR DaysInSelectedPeriod = DATEDIFF(SelectedStartDate, SelectedEndDate, DAY) + 1
			VAR PreviousPeriodStartDate = DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), DAY(SelectedStartDate))
			VAR PreviousPeriodEndDate = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			VAR selectedperiod = SELECTEDVALUE(PeriodDates[Period])
			VAR PreviousQuarterStart = DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), DAY(SelectedStartDate))
			VAR PreviousQuarterEnd = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			VAR PreviousYearStart = DATE(YEAR(SelectedStartDate) - 1, 1, 1)
			VAR PreviousYearEnd = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			
			RETURN
			SWITCH(
			    selectedperiod,
			    "This Month", 
			        CALCULATE(
			            [Occupied Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1),  
			            PeriodDates[Date] <= EOMONTH(DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1), 0)  
			        ),
			    "This Quarter",
			        CALCULATE(
			        [Occupied Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousQuarterStart, 
			        PeriodDates[Date] <= PreviousQuarterEnd   
			        ),
			    "This Year",
			   CALCULATE(
			        [Occupied Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousYearStart, 
			        PeriodDates[Date] <= PreviousYearEnd),
			    "Custom",
			    CALCULATE(
			        [Occupied Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousPeriodStartDate,
			        PeriodDates[Date] <= PreviousPeriodEndDate
			    ),
			    CALCULATE(
			        [Occupied Rate],
			        FILTER(
			            ALL('PeriodDates'),
			            PeriodDates[Date] >= PreviousPeriodStartDate &&
			            PeriodDates[Date] <= PreviousPeriodEndDate
			        )
			    )
			)
			
			```
