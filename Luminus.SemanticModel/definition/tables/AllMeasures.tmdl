	measure 'Unit Occupancy Rate' = ```
			
			var a = DIVIDE(
			    [Occupied Units], 
			    [# Units], 
			    0
			)
			
			var b = [Unit Occupancy Rate old]
			RETURN
			a+b
			```
		formatString: 0.00%;-0.00%;0.00%
