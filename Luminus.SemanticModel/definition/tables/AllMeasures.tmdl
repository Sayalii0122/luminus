table AllMeasures
	lineageTag: 1acb3d4d-9e7a-4c1e-9601-d6f7ead9662f

	measure '# Units' = DISTINCTCOUNT(spaces_historical[unit_name_facility_name])
		formatString: 0
		lineageTag: abf747e7-7fda-4c12-af21-3bd402b53747

	measure 'Occupied Units' =
			
			CALCULATE(
			    DISTINCTCOUNT(spaces_historical[unit_name_facility_name]),
			    'spaces_historical'[is_occupied] = 1
			)
		formatString: 0
		lineageTag: 74547dac-2bf3-4163-b670-4955cc5168fa

	measure 'Total Area' = SUM('spaces_historical'[sq ft / unit])
		lineageTag: 7ee285c2-2c69-4761-bc7b-7ace08b64a82

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Occupied Area' =
			
			CALCULATE(
			   SUM('spaces_historical'[sq ft / unit]),
			    'spaces_historical'[is_occupied] = 1
			)
		lineageTag: fc2b0b3e-9d8d-4cd0-9d5c-d0cb04bc1039

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Area Occupancy Rate' =
			
			var a = DIVIDE(
			    [Occupied Area],
			    [Total Area],
			    0
			)
			
			var b = [Area Occupancy Rate old]
			RETURN
			a + b
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 31c41602-4628-422d-82c5-229b9e305287

	measure 'Area Occupancy Rate Prior Month' = ```
			
			
			VAR SelectedStartDate = MIN(PeriodDates[Date]) 
			VAR SelectedEndDate = MAX(PeriodDates[Date]) 
			VAR DaysInSelectedPeriod = DATEDIFF(SelectedStartDate, SelectedEndDate, DAY) + 1
			VAR PreviousPeriodStartDate = SelectedStartDate - DaysInSelectedPeriod
			VAR PreviousPeriodEndDate = SelectedStartDate - 1
			VAR selectedperiod = SELECTEDVALUE(PeriodDates[Period])
			
			VAR PreviousQuarterStart = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 1, 10, 1), 
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate), 1, 1),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate), 4, 1),
			                DATE(YEAR(SelectedStartDate), 7, 1) )))
			
			VAR PreviousQuarterEnd = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 1, 12, 31),
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate), 3, 31),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate), 6, 30),  
			                DATE(YEAR(SelectedStartDate), 9, 30))))
			
			RETURN
			SWITCH(
			    selectedperiod,
			    "This Month", 
			        CALCULATE(
			            [Area Occupancy Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(EOMONTH(SelectedStartDate, -1)), MONTH(EOMONTH(SelectedStartDate, -1)), 1),  
			            PeriodDates[Date] <= MIN(SelectedEndDate, EOMONTH(SelectedStartDate, -1))  
			        ),
			    "This Quarter",
			        CALCULATE(
			            [Area Occupancy Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= PreviousQuarterStart, 
			            PeriodDates[Date] <= PreviousQuarterEnd   
			        ),
			    "This Year",
			        CALCULATE(
			            [Area Occupancy Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(SelectedStartDate) - 1, 1, 1), 
			            PeriodDates[Date] <= DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate)) 
			        ),
			    CALCULATE(
			        [Area Occupancy Rate],
			        FILTER(
			            ALL('PeriodDates'),
			            PeriodDates[Date] >= PreviousPeriodStartDate &&
			            PeriodDates[Date] <= PreviousPeriodEndDate
			        )
			    )
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 610fa27e-2f07-4115-85fa-8d30f1535e3b

	measure 'Area Occupancy Rate Prior Year' = ```
			
			VAR SelectedStartDate = MIN(PeriodDates[Date]) 
			VAR SelectedEndDate = MAX(PeriodDates[Date]) 
			VAR DaysInSelectedPeriod = DATEDIFF(SelectedStartDate, SelectedEndDate, DAY) + 1
			VAR PreviousPeriodStartDate = DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), DAY(SelectedStartDate))
			VAR PreviousPeriodEndDate = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			VAR selectedperiod = SELECTEDVALUE(PeriodDates[Period])
			VAR PreviousQuarterStart = DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), DAY(SelectedStartDate))
			VAR PreviousQuarterEnd = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			VAR PreviousYearStart = DATE(YEAR(SelectedStartDate) - 1, 1, 1)
			VAR PreviousYearEnd = DATE(YEAR(SelectedEndDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate))
			
			RETURN
			SWITCH(
			    selectedperiod,
			    "This Month", 
			        CALCULATE(
			            [Area Occupancy Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1),  
			            PeriodDates[Date] <= EOMONTH(DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1), 0)  
			        ),
			    "This Quarter",
			        CALCULATE(
			        [Area Occupancy Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousQuarterStart, 
			        PeriodDates[Date] <= PreviousQuarterEnd   
			        ),
			    "This Year",
			   CALCULATE(
			        [Area Occupancy Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousYearStart, 
			        PeriodDates[Date] <= PreviousYearEnd),
			    "Custom",
			    CALCULATE(
			        [Area Occupancy Rate],
			        REMOVEFILTERS(PeriodDates),
			        PeriodDates[Date] >= PreviousPeriodStartDate,
			        PeriodDates[Date] <= PreviousPeriodEndDate
			    ),
			    CALCULATE(
			        [Area Occupancy Rate],
			        FILTER(
			            ALL('PeriodDates'),
			            PeriodDates[Date] >= PreviousPeriodStartDate &&
			            PeriodDates[Date] <= PreviousPeriodEndDate
			        )
			    )
			)
			
			```
		lineageTag: 4fdbe766-830a-4b53-b344-0aaf71e9c605

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Area Occupancy % Change Prior Month' =
			
			[Area Occupancy Rate] - [Area Occupancy Rate Prior Month]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: eee053f1-f25b-465f-ae84-ece25ab8fb2b

	measure 'Area Occupancy % Change Prior Year' = ```
			
			[Area Occupancy Rate] - [Area Occupancy Rate Prior Year]
			
			    
			 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 518fa15c-87b2-45fb-b865-fc489e63a7da

	measure Move-Ins =
			
			CALCULATE(
			    COUNTROWS('unit_turnover'),
			    'unit_turnover'[move_type] = "MOVE_IN",
			    'unit_turnover'[move_date] >= MAX('Calendar'[Date]) - SELECTEDVALUE('Days Parameter'[Days Parameter], 15)
			)
		formatString: 0
		lineageTag: e97372c3-b4fb-4b9f-85ab-4d1b7bd91ffa

	measure Move-Outs =
			
			CALCULATE(
			    COUNTROWS('unit_turnover'),
			    'unit_turnover'[move_type] = "MOVE_OUT",
			    'unit_turnover'[move_date] >= MAX('Calendar'[Date]) - SELECTEDVALUE('Days Parameter'[Days Parameter], 15) -- Default to 15 if none selected
			)
		formatString: 0
		lineageTag: 08fa56e0-aa2f-4e1d-8b2f-7831bcf6079d

