	measure 'Previous Period Occupied Rate' = ```
			
			VAR SelectedStartDate = MIN(PeriodDates[Date]) 
			VAR SelectedEndDate = MAX(PeriodDates[Date]) 
			VAR DaysInSelectedPeriod = DATEDIFF(SelectedStartDate, SelectedEndDate, DAY) + 1
			VAR PreviousPeriodStartDate = SelectedStartDate - DaysInSelectedPeriod
			VAR PreviousPeriodEndDate = SelectedStartDate - 1
			VAR selectedperiod = SELECTEDVALUE(PeriodDates[Period])
			
			VAR PreviousQuarterStart = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 1, 10, 1), 
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate), 1, 1),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate), 4, 1),
			                DATE(YEAR(SelectedStartDate), 7, 1) )))
			
			VAR PreviousQuarterEnd = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 1, 12, 31),
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate), 3, 31),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate), 6, 30),  
			                DATE(YEAR(SelectedStartDate), 9, 30))))
			
			RETURN
			SWITCH(
			    selectedperiod,
			    "This Month", 
			        CALCULATE(
			            [Occupied Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(EOMONTH(SelectedStartDate, -1)), MONTH(EOMONTH(SelectedStartDate, -1)), 1),  
			            PeriodDates[Date] <= MIN(SelectedEndDate, EOMONTH(SelectedStartDate, -1))  
			        ),
			    "This Quarter",
			        CALCULATE(
			            [Occupied Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= PreviousQuarterStart, 
			            PeriodDates[Date] <= PreviousQuarterEnd   
			        ),
			    "This Year",
			        CALCULATE(
			            [Occupied Rate],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(SelectedStartDate) - 1, 1, 1), 
			            PeriodDates[Date] <= DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedEndDate), DAY(SelectedEndDate)) 
			        ),
			    CALCULATE(
			        [Occupied Rate],
			        FILTER(
			            ALL('PeriodDates'),
			            PeriodDates[Date] >= PreviousPeriodStartDate &&
			            PeriodDates[Date] <= PreviousPeriodEndDate
			        )
			    )
			)
			```
