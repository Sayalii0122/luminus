	measure 'MTD Move-Ins' =
			
			CALCULATE(
			    COUNTROWS('unit_turnover'),
			    REMOVEFILTERS('PeriodDates'[Date]),
			    'unit_turnover'[move_type] = "MOVE_IN",MONTH('Date'[Date]) = MONTH(TODAY())&& YEAR('Date'[Date]) = YEAR(TODAY())
			)
		formatString: 0
		lineageTag: a15697b1-1588-4f46-8a16-6b81d5c68e15

	measure 'Occupied Rate' =
			var a =  DIVIDE(sum(spaces_historical[occ_rate]),[Date_diff],0)
			var b = CALCULATE(SUM(result_occupancy[OccupiedRent]), result_occupancy[Size] <> "Facility")
			RETURN a + b
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: c9e9ce73-d1c4-4b23-8604-18b2c6b0cd85

