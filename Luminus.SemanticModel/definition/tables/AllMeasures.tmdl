	measure 'Autopay prior year' = ```
			
			VAR SelectedStartDate = MIN(PeriodDates[Date]) 
			VAR SelectedEndDate = MAX(PeriodDates[Date]) 
			VAR DaysInSelectedPeriod = DATEDIFF(SelectedStartDate, SelectedEndDate, DAY) + 1
			VAR PreviousPeriodStartDate = SelectedStartDate - 365
			VAR PreviousPeriodEndDate = SelectedEndDate -365 - 1
			VAR selectedperiod = SELECTEDVALUE(PeriodDates[Period])
			
			VAR PreviousYearStart = DATE(YEAR(SelectedStartDate) - 1, 1, 1)
			VAR PreviousYearEnd = DATE(YEAR(SelectedStartDate) - 1, 12, 31)
			
			VAR PreviousQuarterStart = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 2, 10, 1), 
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate) - 1, 1, 1),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate) - 1, 4, 1),
			                DATE(YEAR(SelectedStartDate) - 1, 7, 1) )))
			
			VAR PreviousQuarterEnd = 
			    IF(MONTH(SelectedStartDate) <= 3, 
			        DATE(YEAR(SelectedStartDate) - 2, 12, 31),
			        IF(MONTH(SelectedStartDate) <= 6, 
			            DATE(YEAR(SelectedStartDate) - 1, 3, 31),  
			            IF(MONTH(SelectedStartDate) <= 9, 
			                DATE(YEAR(SelectedStartDate) - 1, 6, 30),  
			                DATE(YEAR(SelectedStartDate) - 1, 9, 30))))
			
			RETURN
			SWITCH(
			    selectedperiod,
			    "This Month", 
			        CALCULATE(
			            [% Leases Autopay],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1),  
			            PeriodDates[Date] <= EOMONTH(DATE(YEAR(SelectedStartDate) - 1, MONTH(SelectedStartDate), 1), 0)  
			        ),
			    "This Quarter",
			        CALCULATE(
			            [% Leases Autopay],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= PreviousQuarterStart, 
			            PeriodDates[Date] <= PreviousQuarterEnd   
			        ),
			    "This Year",
			        CALCULATE(
			            [% Leases Autopay],
			            REMOVEFILTERS(PeriodDates),
			            PeriodDates[Date] >= PreviousYearStart, 
			            PeriodDates[Date] <= PreviousYearEnd 
			        ),
			    CALCULATE(
			        [% Leases Autopay],
			        FILTER(
			            ALL('PeriodDates'),
			            PeriodDates[Date] >= PreviousPeriodStartDate &&
			            PeriodDates[Date] <= PreviousPeriodEndDate
			        )
			    )
			)
			
			```
