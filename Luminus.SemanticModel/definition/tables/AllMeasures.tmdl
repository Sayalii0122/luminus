	measure 'Occupied Rate % Change Prior Month' = ```
			
			IF(
			    [Previous Period Occupied Rate] = 0, 
			    1, 
			    DIVIDE([Occupied Rate] - [Previous Period Occupied Rate], [Previous Period Occupied Rate], 0)
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5fea2fb7-e791-422d-adac-fd55a4ba9473

	measure 'Occupied Rate % Change Prior Year' = ```
			
			IF(
			    [Occupied Rate Prior Year] = 0, 
			    1, 
			    DIVIDE([Occupied Rate] - [Occupied Rate Prior Year], [Occupied Rate Prior Year], 0)
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ff085154-3b79-4d2d-9a5a-126830b85f29

	measure 'Days In Unit' = ```
			
			SUMX(
			    unit_turnover,
			    DATEDIFF(
			        unit_turnover[lease_start_date], 
			        unit_turnover[lease_end_date], 
			        DAY
			    )
			)
			```
