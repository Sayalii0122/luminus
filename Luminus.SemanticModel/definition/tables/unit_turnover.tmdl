	column 'sq ft / unit' = ( unit_turnover[unit_depth] * unit_turnover[unit_width] )
		formatString: 0.00
		lineageTag: 1d40dcee-2747-4bc3-a1c9-e9cb08fe8415
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Tenant_name =
			
			VAR TenantList =
			    FILTER(spaces_historical, spaces_historical[unit_id] = unit_turnover[unit_id] && spaces_historical[date] = unit_turnover[move_date])
			VAR SelectedTenant =
			    CALCULATE(FIRSTNONBLANK( spaces_historical[occ_tenant_name],1),TenantList)
			
			RETURN
			    SelectedTenant
		lineageTag: e06dccc0-680d-41c9-b0e7-dbf486461261
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

