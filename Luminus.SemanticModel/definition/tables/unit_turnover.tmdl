				    authorized_views_Schema = #"cubby-production"{[Name="authorized_views",Kind="Schema"]}[Data],
				    unit_turnover_View = authorized_views_Schema{[Name="unit_turnover",Kind="View"]}[Data]
				in
				    unit_turnover_View

