	partition Calendar = calculated
		mode: import
		source =
				
				VAR basetable = CALENDAR(MIN(spaces_historical[date]), MAX(spaces_historical[date]))
				RETURN
				    ADDCOLUMNS(
				        basetable,
				        "Year", YEAR([Date]),
				        "Month", FORMAT([Date], "MMMM"),
				        "Month #", MONTH([Date]),
				        "Week Day", FORMAT([Date], "dddd"),
				        "Week Day Number", WEEKDAY([Date], 2),
				        "Year Month", FORMAT([Date], "MMM-yyyy"),
				        "Year Month Number", YEAR([Date]) * 100 + MONTH([Date]),
				        "End of Month", EOMONTH([Date], 0),
				        "Week Number", WEEKNUM([Date], 2),
				        "Year Week", YEAR([Date]) & "-" & WEEKNUM([Date], 2),
				        "Year Week Number", YEAR([Date]) * 100 + WEEKNUM([Date], 2),
				        "Week Start", [Date] - WEEKDAY([Date], 2) + 1,
				        "Week End", [Date] - WEEKDAY([Date], 2) + 7,
				        "Week Range", FORMAT([Date] - WEEKDAY([Date], 2) + 1, "MM/dd/yyyy") & " - " & FORMAT([Date] - WEEKDAY([Date], 2) + 7, "MM/dd/yyyy"),
				        "QTR", QUARTER([Date]),
				        "Year-QTR", YEAR([Date]) & "-" & QUARTER([Date]),
				        "YearQTRNumber", YEAR([Date]) * 100 + QUARTER([Date])
				    )

	annotation PBI_Id = 4049961a63a0452fa5e3937fc2af8f78

